cd C:\FINANCE\HouseRent

# Create .env.example file
echo "# Database Configuration" > .env.example
echo "DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD_HERE@localhost:5433/rentora" >> .env.example
echo "" >> .env.example
echo "# JWT Configuration" >> .env.example
echo "SECRET_KEY=your_secret_key_here_change_in_production" >> .env.example
echo "ALGORITHM=HS256" >> .env.example
echo "REFRESH_TOKEN_EXPIRE_DAYS=7" >> .env.example
echo "ACCESS_TOKEN_EXPIRE_MINUTES=30" >> .env.example
echo "" >> .env.example
echo "# Cloudinary Configuration" >> .env.example
echo "CLOUDINARY_CLOUD_NAME=your_cloud_name" >> .env.example
echo "CLOUDINARY_API_KEY=your_api_key" >> .env.example
echo "CLOUDINARY_API_SECRET=your_api_secret" >> .env.example